# Relay gateway configuration — copy to .env and fill in. Never commit .env.
# Generate JWT_SECRET locally, e.g. PowerShell:
#   -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
JWT_SECRET=replace-with-random-32-byte-hex

# Local Postgres (service postgresql-x64-17). Set the password you chose at install.
POSTGRES_URL=postgres://relay:relay@localhost:5432/relay?sslmode=disable

# Local Redis-compatible server (Memurai on Windows) — pub/sub + streams.
REDIS_URL=redis://localhost:6379

# Gateway
GATEWAY_PORT=8080
NODE_ID=gw1
MAX_CONN_PER_NODE=10000
SEND_BUFFER_SIZE=256
RATE_LIMIT_MSGS_PER_SEC=20
MAX_MESSAGE_BYTES=16384
# Comma-separated allowed WebSocket Origins for the upgrade check.
ALLOWED_ORIGINS=http://localhost:3000
